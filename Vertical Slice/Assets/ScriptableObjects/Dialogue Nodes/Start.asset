    fadeOut: 0
    _dialogueText: I glance around the cluttered alleyway.
  - hideBox: 0
    _sprite: {fileID: 0}
    _portrait: {fileID: 0}
    _name: 0
    hideSprite: 0
    fadeIn: 0
    fadeOut: 0
    _dialogueText: A flickering light illuminates the cold darkness.
  - hideBox: 0
    _sprite: {fileID: 21300000, guid: 15f200d48a8f39c488f2c5781e81501c, type: 3}
    _portrait: {fileID: 0}
    _name: 0
    hideSprite: 0
    fadeIn: 0
    fadeOut: 0
    _dialogueText: Yuna stands beside one of the dumpsters, smoking silently.
  - hideBox: 0
    _sprite: {fileID: 0}
    _portrait: {fileID: 0}
    _name: 0
    hideSprite: 0
    fadeIn: 0
    fadeOut: 0
    _dialogueText: I clear my throat quietly. She does not look my way.
  - hideBox: 0
    _sprite: {fileID: 0}
    _portrait: {fileID: 21300000, guid: 7da9ab16c2c193647b838223d9c422c3, type: 3}
    _name: 2
    hideSprite: 0
    fadeIn: 0
    fadeOut: 0
    _dialogueText: Hey. Yuna, right?
  - hideBox: 0
    _sprite: {fileID: 21300000, guid: 7ffdd9d9d17e76b4da07913bdfac2855, type: 3}
    _portrait: {fileID: 0}
    _name: 0
    hideSprite: 0
    fadeIn: 0
    fadeOut: 0
    _dialogueText: She glances up, lowering the cigarette.
  - hideBox: 0
    _sprite: {fileID: 0}
    _portrait: {fileID: 0}
    _name: 1
    hideSprite: 0
    fadeIn: 0
    fadeOut: 0
    _dialogueText: What do you want?
  - hideBox: 0
    _sprite: {fileID: 0}
    _portrait: {fileID: 21300000, guid: a684ae1f80a09264584b9c7d9f7df974, type: 3}
    _name: 2
    hideSprite: 0
    fadeIn: 0
    fadeOut: 0
    _dialogueText: Oh. Hi. I was wondering what you were up to here.
  _playerReplyOptions:
  - '"Um... are you doing okay?"'
  - '"Smoking is bad for you."'
